{
  "extends": "@workspace/tsconfig/base.json",
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": false
  },
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node"],
    "emitDeclarationOnly": false,

    "incremental": false,

    "module": "esnext",

    "exactOptionalPropertyTypes": false,
    "erasableSyntaxOnly": true,
    "noEmit": false,

    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["./src"]
}
