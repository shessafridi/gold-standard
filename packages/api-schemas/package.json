{
  "name": "@workspace/api-schemas",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "exports": {
    "./post": {
      "import": "./dist/post.mjs",
      "require": "./dist/post.cjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
