{
  "name": "@workspace/api-schemas",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "exports": {
    "./auth": {
      "import": "./dist/auth.mjs",
      "require": "./dist/auth.cjs"
    },
    "./common": {
      "import": "./dist/common.mjs",
      "require": "./dist/common.cjs"
    },
    "./post": {
      "import": "./dist/post.mjs",
      "require": "./dist/post.cjs"
    },
    "./standard": {
      "import": "./dist/standard.mjs",
      "require": "./dist/standard.cjs"
    },
    "./user": {
      "import": "./dist/user.mjs",
      "require": "./dist/user.cjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@workspace/prettier-config": "workspace:*",
    "@workspace/tsconfig": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "prettier": "@workspace/prettier-config"
}
