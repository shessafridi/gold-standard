{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023"],
    "types": ["node"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "composite": true
  },
  "include": ["src", "prisma.config.ts", "generated"]
}
